<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="700.0"
            prefWidth="1000.0" style="-fx-background-color: #000000;" xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.imanager.controller.SlideShowController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
    </padding>
    <center>
        <StackPane fx:id="stackPane" style="-fx-background-color: #000000;">
            <ImageView fx:id="slideImageView" pickOnBounds="true" preserveRatio="true"/>
        </StackPane>
    </center>
    <bottom>
        <HBox prefHeight="60.0" prefWidth="1000.0" spacing="10.0" BorderPane.alignment="CENTER_RIGHT">
            <padding>
                <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
            </padding>
            <children>
                <Button fx:id="btnPrev" mnemonicParsing="false" onAction="#prevImage" text="Prev"/>
                <Button fx:id="btnNext" mnemonicParsing="false" onAction="#nextImage" text="Next"/>
                <Button fx:id="btnZoomIn" mnemonicParsing="false" onAction="#zoomIn" onMousePressed="#stopZooming" text="Zoom In"/>
                <Button fx:id="btnZoomOut" mnemonicParsing="false" onAction="#zoomOut" onMousePressed="#stopZooming" text="Zoom Out"/>
                <Button fx:id="btnPlay" mnemonicParsing="false" onAction="#startPlay" text="Play"/>
                <Button fx:id="btnStop" mnemonicParsing="false" onAction="#stopPlay" text="Stop"/>
                <Label fx:id="pageLabel" prefHeight="40.0" prefWidth="100.0" style="-fx-background-color: #83d9b6;"
                       text="0/0" textAlignment="CENTER">
                    <font>
                        <Font size="24.0"/>
                    </font>
                </Label>
            </children>
        </HBox>
    </bottom>
</BorderPane>
