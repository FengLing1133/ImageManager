<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<BorderPane prefHeight="700.0" minWidth="600.0" styleClass="main-root" xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.imanager.controller.MainController">
    <top>
        <HBox spacing="10.0" alignment="CENTER_LEFT" styleClass="top-bar" prefHeight="50.0">
            <padding>
                <Insets bottom="5.0" left="15.0" right="15.0" top="5.0"/>
            </padding>
            <children>
                <Button fx:id="btnBack" onAction="#onBack" prefWidth="40.0" prefHeight="36.0" styleClass="button toolbar-btn">
                    <graphic>
                        <ImageView fitWidth="20" fitHeight="20" preserveRatio="true">
                            <image>
                                <Image url="@icons/back.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                </Button>
                <Button fx:id="btnUndo" onAction="#onUndo" prefWidth="40.0" prefHeight="36.0" styleClass="button toolbar-btn">
                    <graphic>
                        <ImageView fitWidth="20" fitHeight="20" preserveRatio="true">
                            <image>
                                <Image url="@icons/forward.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                </Button>
                <TextField fx:id="pathField" text="" promptText="输入路径..."
                           HBox.hgrow="ALWAYS" prefWidth="800.0" prefHeight="40.0"/>
            </children>
        </HBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.22" minHeight="400.0" minWidth="500.0" BorderPane.alignment="CENTER">
            <items>
                <AnchorPane minWidth="150.0" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
                    <children>
                        <ScrollPane fitToHeight="true" fitToWidth="true" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                            <content>
                                <AnchorPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                    <children>
                                        <TreeView fx:id="dirTreeView" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
                                    </children>
                                </AnchorPane>
                            </content>
                        </ScrollPane>
                    </children>
                </AnchorPane>
                <AnchorPane minWidth="300.0" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
                    <children>
                        <ScrollPane fx:id="imageScrollPane" hbarPolicy="NEVER" fitToWidth="true" fitToHeight="false" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                            <content>
                                <AnchorPane fx:id="imageAnchorPane" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                                    <children>
                                        <FlowPane fx:id="imageFlowPane" hgap="10.0" vgap="10.0" onMouseClicked="#clickBlank"
                                                  AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
                                            <padding>
                                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                            </padding>
                                        </FlowPane>
                                        <Label fx:id="emptyTipLabel" text="暂无内容"
                                               style="-fx-font-size: 18px;"
                                               AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
                                               AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
                                               alignment="CENTER" textAlignment="CENTER" maxWidth="Infinity"
                                               maxHeight="Infinity" visible="false"/>
                                    </children>
                                </AnchorPane>
                            </content>
                        </ScrollPane>
                    </children>
                </AnchorPane>
            </items>
        </SplitPane>
    </center>
    <bottom>
        <BorderPane prefHeight="40.0" styleClass="status-bar">
            <left>
                <Label fx:id="tipLabel" text="Welcome to Image Manager" BorderPane.alignment="CENTER_LEFT">
                    <font>
                        <Font size="14.0"/>
                    </font>
                    <padding>
                        <Insets left="10.0"/>
                    </padding>
                </Label>
            </left>
            <right>
                <HBox spacing="10.0" alignment="CENTER_RIGHT" style="-fx-padding: 0 5 0 0;">
                    <Button fx:id="btnPlay" mnemonicParsing="false" onAction="#openSlideShow" prefHeight="30.0"
                            prefWidth="75.0" styleClass="primary-btn play-btn">
                        <graphic>
                            <ImageView fitWidth="18" fitHeight="18" preserveRatio="true">
                                <image>
                                    <Image url="@icons/play.png"/>
                                </image>
                            </ImageView>
                        </graphic>
                    </Button>
                    <!-- 可在此添加更多操作按钮 -->
                </HBox>
            </right>
        </BorderPane>
    </bottom>
</BorderPane>
