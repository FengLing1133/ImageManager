<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="800.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.imanager.controller.MainController">
   <top>
      <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-background-color: #e6f0fa;" prefHeight="50.0">
         <padding>
            <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
         </padding>
         <children>
            <Button fx:id="btnBack" text="←" onAction="#onBack" prefWidth="40.0"/>
            <Button fx:id="btnUndo" text="⟲" onAction="#onUndo" prefWidth="40.0"/>
            <TextField fx:id="pathField" text="" promptText="路径..." style="-fx-background-color: #ffffff; -fx-padding: 0 10 0 10;" HBox.hgrow="ALWAYS" prefWidth="800.0"/>
         </children>
      </HBox>
   </top>
   <center>
      <SplitPane dividerPositions="0.25" layoutY="50.0" minHeight="400.0" minWidth="500.0" BorderPane.alignment="CENTER">
        <items>
          <AnchorPane maxWidth="1.7976931348623157E308" minHeight="300.0" minWidth="160.0">
               <children>
                  <ScrollPane fitToHeight="true" fitToWidth="true" maxWidth="1.7976931348623157E308" minHeight="290.0" minWidth="155.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <content>
                      <AnchorPane maxWidth="1.7976931348623157E308" minHeight="280.0" minWidth="150.0">
                           <children>
                              <TreeView fx:id="dirTreeView" maxWidth="1.7976931348623157E308" minHeight="200.0" minWidth="150.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
                           </children>
                        </AnchorPane>
                    </content>
                  </ScrollPane>
               </children>
            </AnchorPane>
          <AnchorPane maxWidth="1.7976931348623157E308" minHeight="300.0" minWidth="300.0">
               <children>
                  <ScrollPane fx:id="imageScrollPane" hbarPolicy="NEVER" layoutX="194.0" layoutY="148.0" maxWidth="1.7976931348623157E308" minHeight="290.0" minWidth="295.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                     <content>
                        <AnchorPane fx:id="imageAnchorPane" maxWidth="1.7976931348623157E308" minHeight="200.0" minWidth="0.0">
                           <children>
                              <FlowPane fx:id="imageFlowPane" hgap="10.0" vgap="10.0" minHeight="200.0" minWidth="0.0" onMouseClicked="#clickBlank" AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="0.0">
                                 <padding>
                                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                 </padding>
                              </FlowPane>
                           </children>
                        </AnchorPane>
                     </content>
                  </ScrollPane>
               </children>
            </AnchorPane>
        </items>
      </SplitPane>
   </center>
   <bottom>
      <BorderPane prefHeight="40.0" style="-fx-background-color: transparent;">
         <left>
            <Label fx:id="tipLabel" text="Welcome to Image Manager" BorderPane.alignment="CENTER_LEFT">
               <font>
                  <Font size="14.0" />
               </font>
               <padding>
                  <Insets left="10.0" />
               </padding>
            </Label>
         </left>
         <right>
            <HBox spacing="10.0" alignment="CENTER_RIGHT">
               <Button fx:id="btnPlay" mnemonicParsing="false" onAction="#openSlideShow" prefHeight="30.0" prefWidth="75.0" text="Play" />
               <!-- 可在此添加更多操作按钮 -->
            </HBox>
         </right>
      </BorderPane>
   </bottom>
</BorderPane>
